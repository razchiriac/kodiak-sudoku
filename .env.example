# Postgres connection string. For Supabase, use the "Connection pooling"
# transaction-mode URL on Vercel; the direct URL is fine for local dev and
# scripts. Drizzle and the import script both read this variable.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sudoku

# Public Supabase keys safe to ship to the browser. The publishable key
# is scoped by RLS, so leaking it does not give cross-user access. This
# is Supabase's new "API keys v2" naming; sb_publishable_* values go
# here. (Old anon JWTs also work in this slot if your project predates
# the new format.)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Service role key. NEVER expose to the browser. Only used in scripts and
# in a small number of server-only route handlers if absolutely needed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL used for auth redirect URLs and absolute links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sentry DSN. Empty disables Sentry locally.
NEXT_PUBLIC_SENTRY_DSN=

# Feature flags. Resolution order in lib/flags.ts:
#   1. Vercel Edge Config (via EDGE_CONFIG connection string below) -
#      primary control plane, flipped from the Vercel Flags dashboard.
#   2. FLAG_<NAME> env var below - local-dev fallback + kill switch.
#   3. The flag's declared defaultValue.
#
# Each FLAG_* var is strictly matched against the literal string "true";
# anything else (empty, "1", "yes") is treated as off. Leave unset in
# production to rely entirely on Edge Config.
FLAG_PB_RIBBON=false
FLAG_HAPTICS=false

# Vercel Edge Config connection string. Auto-injected by Vercel when you
# connect an Edge Config store to this project (Storage tab -> Create ->
# Edge Config -> Connect project). Leave empty locally; flags will fall
# back to the FLAG_* env vars above.
EDGE_CONFIG=

# Secret used by the Vercel Flags toolbar route
# (app/.well-known/vercel/flags/route.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Leave empty locally if you don't use the toolbar.
FLAGS_SECRET=

# Vercel personal access token used ONLY by `npm run flags:sync` to
# create missing flags in Edge Config AND register them in the Flags
# dashboard. Generate at https://vercel.com/account/tokens. Scope it
# to the team that owns the project. Do NOT commit; lives in
# .env.local only.
VERCEL_API_TOKEN=
# (optional) Team ID, e.g. "team_xxx". If unset the sync script asks
# the token which teams it can see and uses the first one — fine as
# long as this token belongs to a single team.
VERCEL_TEAM_ID=
# (optional) Project ID or slug, e.g. "kodiak-sudoku" or "prj_xxx".
# Only needed so the sync script can register new flags in the Vercel
# Flags dashboard (the /flags/active page). If unset we try to
# auto-discover by listing the team's projects.
VERCEL_PROJECT_ID=

# ──────────────────────────────────────────────────────────
# Google OAuth (RAZ-36)
# ──────────────────────────────────────────────────────────
# Google OAuth credentials live in the Supabase dashboard, NOT in this
# repo's environment. No GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET env
# vars are needed here. To enable "Continue with Google" sign-in:
#
# 1. Google Cloud Console → APIs & Services → Credentials →
#    Create OAuth client ID (type: Web application).
#    - Authorized redirect URI:
#      https://<project-ref>.supabase.co/auth/v1/callback
#
# 2. Supabase Dashboard → Authentication → Providers → Google → Enable.
#    Paste the Client ID and Client Secret from step 1.
#
# 3. Supabase Dashboard → Authentication → URL Configuration:
#    - Site URL: your production URL
#    - Redirect URLs allowlist:
#      http://localhost:3000/auth/callback
#      https://your-production-domain/auth/callback
#      https://*.vercel.app/auth/callback
# ──────────────────────────────────────────────────────────

# RAZ-7: Web Push VAPID keys for daily reminder notifications.
# Generate with: npx web-push generate-vapid-keys
# The public key is embedded in the browser bundle (safe); the
# private key stays server-side. VAPID_SUBJECT should be a mailto:
# or https: URL identifying the app operator.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com

# Secret used by Vercel to authenticate cron requests. Vercel auto-
# injects this as the Authorization: Bearer header. Set locally if
# you want to test the cron endpoint with auth.
CRON_SECRET=

# RAZ-73: Dev-only opt-in switch for the Playwright auth bypass at
# /api/test/login. The route checks BOTH that NODE_ENV !== "production"
# AND that this var is exactly "1"; either guard failing returns 404
# (not 403, on purpose). Required to run the authed e2e specs locally
# or in CI. Never set this in a production environment.
ENABLE_TEST_LOGIN=
