# dependencies
node_modules
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage

# playwright: generated artifacts (reports, traces, screenshots)
playwright-report/
test-results/
.playwright/
# RAZ-73: storage state captured by the dev-only auth setup. Never
# commit — even though the test user is fake, the file contains a
# real Supabase session JWT against whatever project the dev server
# is pointed at.
playwright/.auth/

# next.js
.next
out

# production
build
dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# local data (raw kaggle csv etc.)
data/raw
data/processed

# drizzle: ignore everything inside drizzle/ (e.g. local snapshot
# JSONs from drizzle-kit) but explicitly track our hand-written
# migrations so the database schema is versioned with the code.
# Note: `drizzle/` (the dir itself) cannot be excluded with a trailing
# slash if we want to un-include files inside it — git won't recurse
# into an excluded directory. Using `drizzle/*` lets us un-include
# the migrations subtree.
drizzle/*
!drizzle/migrations/
!drizzle/migrations/**
.cursor/

# Claude Code session state (worktrees, plans, memory — all ephemeral)
.claude/

# Android TWA: Gradle build cache and compiled outputs.
# Source files (gradlew, build.gradle, app/src/, etc.) are tracked.
android/twa-app/.gradle/
android/twa-app/build/
android/twa-app/app/build/
android/twa-app/*.apk
android/twa-app/*.aab
android/twa-app/*.idsig

# Content POC run artifacts (webm recordings, JSON dumps).
# The scripts that generate them are tracked; the outputs are not.
artifacts/
